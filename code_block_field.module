<?php

declare(strict_types=1);

/**
 * @file
 * Primary module hooks for Code Block Field.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_theme().
 */
function code_block_field_theme(): array {
  return [
    'code_block_field' => [
      'variables' => [
        'instance_id' => '',
        'html' => '',
        'css' => '',
        'js' => '',
        'entity_type' => '',
        'entity_id' => NULL,
        'field_name' => '',
        'delta' => 0,
        'langcode' => '',
        'shadow_mode' => 'open',
        'inline_enabled' => FALSE,
        'attributes' => [],
      ],
      'template' => 'code-block-field',
    ],
  ];
}

/**
 * Implements hook_help().
 */
function code_block_field_help(string $route_name, RouteMatchInterface $route_match): string {
  switch ($route_name) {
    case 'help.page.code_block_field':
      $output = '<h3>' . t('О модуле') . '</h3>';
      $output .= '<p>' . t('Модуль Code Block Field добавляет новый тип поля, который хранит связку HTML / CSS / JS и рендерит её внутри изолированного Shadow DOM. Содержимое блока можно редактировать инлайн (текст, изображения, ссылки) без открытия формы сущности.') . '</p>';
      $output .= '<h3>' . t('Использование') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('Добавьте поле к любой сущности (node, paragraph, block_content, taxonomy_term и т.д.).') . '</li>';
      $output .= '<li>' . t('В форме редактирования сущности напишите HTML / CSS / JS в редакторе CodeMirror.') . '</li>';
      $output .= '<li>' . t('На странице рендера нажмите плавающую кнопку «Режим редактирования» (видна пользователям с правом «use code block field inline editor»), чтобы редактировать текст, изображения и ссылки прямо на месте.') . '</li>';
      $output .= '</ul>';
      return $output;

    case 'code_block_field.settings':
      return '<p>' . t('Глобальные настройки HTML-фильтра, хранилища файлов и инлайн-редактора для полей Code Block.') . '</p>';
  }
  return '';
}

/**
 * Implements hook_element_info_alter().
 *
 * Ensures the vertical_tabs element used by our widget has the right
 * defaults even on entities that don't normally use them.
 */
function code_block_field_element_info_alter(array &$types): void {
  // Intentionally empty placeholder — kept for future hooks.
}

/**
 * Implements hook_field_widget_info_alter().
 *
 * No-op for now; kept so other modules can decorate our widget if needed.
 */
function code_block_field_field_widget_info_alter(array &$info): void {
}

/**
 * Implements hook_entity_presave().
 *
 * For host entities that don't run our widget (e.g. inline-saved ones), make
 * sure asset file usage stays in sync. The actual usage registration for
 * widget-submitted values happens in CodeBlockWidget::extractFormValues().
 *
 * Also runs the auto-asset-assignment routine: every <img> inside the
 * field's HTML that does not have a data-cbf-asset attribute gets a unique
 * key assigned, and if its src points to a Drupal managed file, the file
 * is looked up and registered in the assets map (with file.usage tracking).
 *
 * This hook fires for every entity type (including config entities such as
 * FieldStorageConfig), so we must guard against entities that do not
 * implement FieldableEntityInterface — calling getFieldDefinitions() /
 * getFields() on them would throw a fatal error.
 */
function code_block_field_entity_presave(\Drupal\Core\Entity\EntityInterface $entity): void {
  if (!$entity instanceof \Drupal\Core\Entity\FieldableEntityInterface) {
    return;
  }
  $config = \Drupal::config('code_block_field.settings');
  $auto_assign = (bool) $config->get('auto_assign_asset_keys');
  foreach ($entity->getFields() as $field_name => $fieldItemList) {
    $definition = $fieldItemList->getFieldDefinition();
    if ($definition->getType() !== 'code_block') {
      continue;
    }
    foreach ($fieldItemList as $delta => $item) {
      // Auto-assign data-cbf-asset to <img> tags that don't have one.
      if ($auto_assign && !empty($item->html)) {
        $assets = is_array($item->assets) ? $item->assets : [];
        $new_html = \Drupal\code_block_field\ProcessImages::process(
          (string) $item->html,
          $assets,
          $entity
        );
        if ($new_html !== $item->html) {
          $item->html = $new_html;
        }
        if ($assets !== (is_array($item->assets) ? $item->assets : [])) {
          $item->assets = $assets;
        }
      }

      // Register file usage for all known assets.
      $assets = is_array($item->assets) ? $item->assets : [];
      foreach ($assets as $asset) {
        $fid = $asset['fid'] ?? 0;
        if (!$fid) {
          continue;
        }
        $file = \Drupal::entityTypeManager()->getStorage('file')->load($fid);
        if ($file) {
          \Drupal::service('file.usage')->add($file, 'code_block_field', $entity->getEntityTypeId(), (int) ($entity->id() ?: 0));
        }
      }
    }
  }
}

/**
 * Implements hook_entity_delete().
 *
 * Releases file usage for all code_block assets attached to the entity.
 * Same guard as in hook_entity_presave(): only fieldable entities have
 * fields to iterate.
 */
function code_block_field_entity_delete(\Drupal\Core\Entity\EntityInterface $entity): void {
  if (!$entity instanceof \Drupal\Core\Entity\FieldableEntityInterface) {
    return;
  }
  foreach ($entity->getFields() as $fieldItemList) {
    if ($fieldItemList->getFieldDefinition()->getType() !== 'code_block') {
      continue;
    }
    foreach ($fieldItemList as $item) {
      $assets = is_array($item->assets) ? $item->assets : [];
      foreach ($assets as $asset) {
        $fid = $asset['fid'] ?? 0;
        if (!$fid) {
          continue;
        }
        $file = \Drupal::entityTypeManager()->getStorage('file')->load($fid);
        if ($file) {
          \Drupal::service('file.usage')->delete($file, 'code_block_field', $entity->getEntityTypeId(), (int) $entity->id(), 0);
        }
      }
    }
  }
}
